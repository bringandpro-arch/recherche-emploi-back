# ───────────────────────────────────────────────────────────────
# Exemple de configuration. Copier en `.env` et renseigner.
# NE JAMAIS committer le fichier `.env` réel.
# ───────────────────────────────────────────────────────────────

# --- Base de données ---
POSTGRES_DB=recherche_emploi
POSTGRES_USER=recherche
POSTGRES_PASSWORD=change-me
DB_URL=jdbc:postgresql://localhost:5432/recherche_emploi

# --- Scan périodique (cron Spring : sec min heure jour mois jourSemaine) ---
SCAN_CRON=0 0 */3 * * *

# --- LLM (provider remplaçable derrière LlmProvider) ---
# Valeurs possibles : anthropic | noop
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Modèle économique pour le scoring de masse ; voir PLAN.md §7
LLM_MODEL=claude-haiku-4-5
# Plafond mensuel indicatif (USD) pour les appels IA
LLM_MONTHLY_BUDGET_USD=15

# --- Telegram (BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Sources : France Travail (portail développeur) ---
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_ENABLED=true

# --- Sources : Adzuna ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_ENABLED=true

# --- Sources : Remotive (API publique, pas de clé) ---
REMOTIVE_ENABLED=true

# --- CORS (origine du front Ionic) ---
CORS_ALLOWED_ORIGINS=http://localhost:8100
