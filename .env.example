# ───────────────────────────────────────────────────────────────
# Exemple de configuration LOCALE (dev / tests). En production, la config et les
# secrets vivent dans SSM Parameter Store et les variables d'env des Lambda (SAM).
# Copier en `.env` pour le local. NE JAMAIS committer le `.env` réel.
# ───────────────────────────────────────────────────────────────

# --- AWS ---
AWS_REGION=eu-west-3
# Pour Bedrock, vérifier une région où Claude est disponible (ex. eu-west-1/-3, us-east-1).
BEDROCK_REGION=eu-west-1

# --- DynamoDB (noms de tables, surchargés par SAM en prod) ---
TABLE_PROFILES=Profiles
TABLE_OFFERS=Offers
TABLE_SCORED=ScoredOffers
TABLE_SEEN=SeenOffers
TABLE_SCANRUNS=ScanRuns
TABLE_NOTIFICATIONS=Notifications

# --- Cognito ---
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# --- Scan périodique (expression de planification EventBridge Scheduler) ---
SCAN_SCHEDULE=rate(3 hours)

# --- LLM (provider remplaçable derrière LlmProvider) ---
# Valeurs : bedrock | noop
LLM_PROVIDER=bedrock
# Modèle Bedrock pour le scoring de masse (ID Bedrock, préfixe fournisseur)
LLM_MODEL=anthropic.claude-haiku-4-5
# Modèle pour la génération de pitch (qualité rédactionnelle)
LLM_MODEL_PITCH=anthropic.claude-sonnet-4-6
# Plafond mensuel indicatif (USD) pour les appels IA
LLM_MONTHLY_BUDGET_USD=8

# --- Telegram (BotFather) ---
TELEGRAM_BOT_TOKEN=

# --- Sources : France Travail (portail développeur) ---
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_ENABLED=true

# --- Sources : Adzuna ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_ENABLED=true

# --- Sources : Remotive (API publique, pas de clé) ---
REMOTIVE_ENABLED=true

# --- Sources : The Muse (F16 — clé optionnelle, fonctionne sans clé à débit réduit) ---
THE_MUSE_API_KEY=
THE_MUSE_ENABLED=true

# --- Sources : RemoteOK (F16 — API publique, pas de clé ; attribution demandée) ---
REMOTEOK_ENABLED=true

# --- Sources : RSS générique (F16 — flux RSS 2.0, URLs séparées par des virgules) ---
# Ex. Free-Work / flux divers. Vide => connecteur RSS désactivé.
RSS_FEEDS=

# --- CORS (origine du front) ---
CORS_ALLOWED_ORIGINS=https://emplois.cachi.fr,http://localhost:8100
